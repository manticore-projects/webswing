# .snyk — Snyk ignore policy for Ubuntu Noble base-image CVEs that have no
# available fix in the Ubuntu package repositories.
#
# Each entry documents:
#   - why the CVE cannot be remediated via the Dockerfile
#   - the assessed runtime impact
#   - a review date — reassess when Ubuntu publishes a patched package
#
# Renew / remove entries whenever `apt-cache policy <pkg>` shows a fixed
# version is available, or when the base image is changed to a distro that
# ships a patched version.

version: v1.25.0

ignore:
  # ── tar CVE-2025-45582 (Directory Traversal) ──────────────────────────────
  # Ubuntu has no fix for Noble. Upstream tar developers have stated the
  # behaviour is working as documented (two-step symlink extraction).
  # Runtime impact: NONE — the container never extracts untrusted tar archives
  # at runtime. tar is only used during the Docker build stage.
  CVE-2025-45582:
  - '*':
      reason: >
        No Ubuntu Noble fix available. Upstream considers this working as
        designed. tar is not invoked on untrusted archives at container runtime;
        exposure is build-time only.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── glibc CVE-2016-20013 (Allocation without Limits, CVSS 7.5) ───────────
  # Open since 2016; Ubuntu has never backported a fix for any release.
  # Runtime impact: LOW — requires a network-accessible service to craft
  # specially shaped locale data. The container does not expose libc locale
  # APIs to untrusted network input.
  CVE-2016-20013:
  - '*':
      reason: >
        No Ubuntu fix available (open since 2016). Fundamental glibc dependency;
        cannot be removed. Container does not expose locale API to untrusted
        network input.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── coreutils CVE-2016-2781 (Improper Input Validation, CVSS 6.5) ─────────
  # Open since 2016; no Ubuntu backport. Affects `chroot` when invoked by
  # a process that can override $TIOCSTI — not applicable in this container
  # (no interactive shell exposed, USER is non-root webswing).
  CVE-2016-2781:
  - '*':
      reason: >
        No Ubuntu fix available (open since 2016). Requires local shell access
        and TIOCSTI privilege. Container runs as non-root with no interactive
        shell exposed.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── expat/libexpat1 (Algorithmic Complexity) ──────────────────────────────
  # libexpat1 is a required dependency of libxrender1 / libxext6 / fontconfig.
  # Cannot be removed while X11 libraries are present.
  # Reassess when Ubuntu publishes a patched libexpat1 for Noble.
  SNYK-UBUNTU2404-EXPAT-*:
  - '*':
      reason: >
        libexpat1 is a transitive dependency of X11/fontconfig libraries
        required by Webswing. Cannot be removed. No Ubuntu Noble fix available.
        Reassess on next Ubuntu security advisory for libexpat1.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── tar CVE-2026-5704 (Unrestricted Upload / CWE-434, CVSS 5.5) ───────────
  # No Ubuntu Noble fix available. tar is a core utility; cannot be removed.
  # Runtime impact: LOW — container does not accept or extract user-supplied
  # archives at runtime.
  CVE-2026-5704:
  - '*':
      reason: >
        No Ubuntu Noble fix available. tar is a core utility that cannot be
        removed. Container never extracts untrusted archives at runtime.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── glibc CVE-2026-4046 / CVE-2026-4437 / CVE-2026-4438 ─────────────────
  # No Ubuntu Noble fix available for any of these. glibc is a fundamental
  # dependency; cannot be removed or replaced.
  CVE-2026-4046:
  - '*':
      reason: >
        No Ubuntu Noble fix available. Fundamental glibc dependency; cannot be
        removed. Reassess when Ubuntu publishes a patched glibc for Noble.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'
  CVE-2026-4437:
  - '*':
      reason: >
        No Ubuntu Noble fix available. Fundamental glibc dependency; cannot be
        removed. Reassess when Ubuntu publishes a patched glibc for Noble.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'
  CVE-2026-4438:
  - '*':
      reason: >
        No Ubuntu Noble fix available. Fundamental glibc dependency; cannot be
        removed. Reassess when Ubuntu publishes a patched glibc for Noble.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── util-linux CVE-2026-27456 (TOCTOU) ───────────────────────────────────
  # No Ubuntu Noble fix available. util-linux/bsdutils are core OS utilities
  # that cannot be removed.
  CVE-2026-27456:
  - '*':
      reason: >
        No Ubuntu Noble fix available. util-linux is a core OS package that
        cannot be removed. Reassess when Ubuntu publishes a fix for Noble.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── pam/libpam-modules CVE-2025-8941 (Directory Traversal, CVSS 7.8) ─────
  # No Ubuntu Noble fix available. PAM is a fundamental authentication
  # framework dependency. Runtime impact is low: the container runs as a
  # non-root user with no interactive login or PAM-authenticated services.
  CVE-2025-8941:
  - '*':
      reason: >
        No Ubuntu Noble fix available. PAM is a fundamental OS dependency.
        Container runs as non-root (webswing) with no interactive shell, PAM
        login services, or su/sudo exposed. Local privilege escalation requires
        an attacker already inside the container.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'

  # ── wget CVE-2021-31879 (Open Redirect) ───────────────────────────────────
  # wget has been purged from the runtime image (see Dockerfile).
  # This entry covers any scanner that still flags the base-image layer before
  # the purge RUN step is accounted for.
  CVE-2021-31879:
  - '*':
      reason: >
        wget is explicitly purged from the runtime image in the Dockerfile.
        Healthcheck replaced with a pure bash /dev/tcp built-in check.
        No Ubuntu Noble fix available in any case.
      expires: '2026-05-14T00:00:00.000Z'
      created: '2025-05-14T00:00:00.000Z'
