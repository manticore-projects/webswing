# IDE / editor
.idea/
*.iml
.vscode/
.zed/
*.swp
*~

# Build outputs (will be built inside the container)
**/build/
**/out/
**/target/
**/bin/

# Gradle caches (wrapper will download fresh)
.gradle/

# Node modules (will be installed during build)
**/node_modules/

# Git
.git/
.gitignore

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# Docs / CI
*.md
.github/
.semgrepignore

# FIX (secret leakage): exclude credential and certificate files so they can
# never be included in the build context — even accidentally.  A file that
# never enters the context cannot be baked into an image layer.
#
# Environment / secrets
.env
*.env
.env.*
secrets/
credentials/
**/.secrets/

# Private keys and certificates
*.pem
*.key
*.crt
*.cer
*.der
*.p7b
*.p12
*.pfx

# Java keystores and truststores
*.jks
*.keystore
*.truststore

# Cloud / service credentials
*.json.key
gcloud-key*.json
service-account*.json