{
  "name": "webswing-js",
  "version": "2.7.0",
  "description": "Webswing javascript client",
  "main": "webswing-selector.js",
  "scripts": {
    "build": "npm run clean && npm run proto && npm run type-check && webpack --config webpack-dev.config.js",
    "build-prod": "npm run clean && npm run proto && npm run type-check && webpack --config webpack-prd.config.js",
    "rebuild": "webpack --config webpack-rebuild.config.js",
    "clean": "rimraf .tmp",
    "start": "npm run serve:dev",
    "type-check": "tsc --noEmit",
    "proto": "npm run proto-in && npm run proto-out && npm run proto-frame && npm run proto-common && npm run proto-ts-in && npm run proto-ts-out && npm run proto-ts-frame && npm run proto-ts-common",
    "proto-in": "pbjs -t static-module -w commonjs -o src/main/webapp/javascript/proto/proto.in.js --no-decode --no-verify --no-delimited ../../webswing-app-toolkit/src/main/protobuf/AppFrameProtoIn.proto",
    "proto-out": "pbjs -t static-module -w commonjs -o src/main/webapp/javascript/proto/proto.out.js --no-encode --no-verify --no-delimited ../../webswing-app-toolkit/src/main/protobuf/AppFrameProtoOut.proto",
    "proto-frame": "pbjs -t static-module -w commonjs -o src/main/webapp/javascript/proto/proto.frame.js --no-verify --no-delimited ../../webswing-app-toolkit/src/main/protobuf/ServerBrowserFrameProto.proto",
    "proto-common": "pbjs -t static-module -w commonjs -o src/main/webapp/javascript/proto/proto.common.js --no-verify --no-delimited ../../webswing-app-toolkit/src/main/protobuf/CommonProto.proto",
    "proto-ts-in": "pbts -o src/main/webapp/javascript/proto/proto.in.d.ts src/main/webapp/javascript/proto/proto.in.js",
    "proto-ts-out": "pbts -o src/main/webapp/javascript/proto/proto.out.d.ts src/main/webapp/javascript/proto/proto.out.js",
    "proto-ts-frame": "pbts -o src/main/webapp/javascript/proto/proto.frame.d.ts src/main/webapp/javascript/proto/proto.frame.js",
    "proto-ts-common": "pbts -o src/main/webapp/javascript/proto/proto.common.d.ts src/main/webapp/javascript/proto/proto.common.js",
    "license-report": "license-report --output=html --only=prod 2>&1 > target/3rd-party-js-report.html"
  },
  "keywords": [
    "webswing"
  ],
  "author": "Viktor Meszaros",
  "overrides": {
    "glob": "^12.0.0",
    "inflight": "^2.0.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/jquery": "^3.5.0",
    "@types/jquery.fileupload": "^9.22.0",
    "@types/node": "^22.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "compression-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "license-report": "^6.7.0",
    "mini-css-extract-plugin": "^2.9.0",
    "npm-run-all": "^4.1.5",
    "protobufjs-cli": "^1.1.3",
    "rimraf": "^5.0.0",
    "sass": "^1.87.0",
    "sass-loader": "^16.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.8.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.0",
    "@types/dompurify": "^3.0.5"
  },
  "dependencies": {
    "jquery": "^3.7.0",
    "jquery-ui": "^1.14.0",
    "bootstrap-sass": "^3.4.3",
    "protobufjs": "^7.4.0",
    "webswing-directdraw-javascript": "../../webswing-directdraw/webswing-directdraw-javascript",
    "blueimp-file-upload": "^10.1.0",
    "jquery.iframe-transport": "^1.0.0",
    "pdfjs-dist-viewer-min": "^2.4.456",
    "dompurify": "^3.2.4"
  },
  "allowScripts": {
    "protobufjs@7.5.8": true,
    "@parcel/watcher@2.5.6": true
  }
}
